        { "key": "payerFax", "label": "Fax", "type": "phone", "colSpan": 1 },
        { "key": "claimsAddress", "label": "Claims Address", "type": "text", "colSpan": 2 },
        { "key": "payerCity", "label": "City", "type": "text", "colSpan": 1 },
        { "key": "payerState", "label": "State", "type": "text", "colSpan": 1 },
        { "key": "payerZip", "label": "ZIP", "type": "text", "colSpan": 1 },
        { "key": "electronicPayerId", "label": "Electronic Payer ID", "type": "text", "colSpan": 1 }
      ]
