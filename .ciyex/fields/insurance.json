{
  "tabKey": "insurance",
  "fhirResources": ["Coverage", "Organization"],
  "sections": [
    {
      "key": "payer-info",
      "title": "Insurance Payer",
      "columns": 2,
      "visible": true,
      "fields": [
        { "key": "payerName", "label": "Payer / Insurance Company", "type": "lookup", "required": true, "colSpan": 2, "lookupConfig": { "endpoint": "/api/fhir-resource/insurance", "displayField": "name", "valueField": "id", "searchable": true }, "fhirMapping": { "resource": "Coverage", "path": "payor[0].display", "type": "string" } },
        { "key": "planName", "label": "Plan Name", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "class[?type=plan].name", "type": "string" } },
        { "key": "coverageType", "label": "Coverage Type", "type": "select", "colSpan": 1, "options": [{ "label": "Primary", "value": "primary" }, { "label": "Secondary", "value": "secondary" }, { "label": "Tertiary", "value": "tertiary" }, { "label": "Workers Comp", "value": "workers-comp" }, { "label": "Auto/Accident", "value": "auto" }] },
        { "key": "memberId", "label": "Member ID", "type": "text", "required": true, "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "subscriberId", "type": "string" } },
        { "key": "groupNumber", "label": "Group Number", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "class[?type=group].value", "type": "string" } },
        { "key": "groupName", "label": "Group Name", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "class[?type=group].name", "type": "string" } },
        { "key": "subscriberName", "label": "Subscriber Name", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "subscriber.display", "type": "string" } },
        { "key": "relationship", "label": "Relationship to Subscriber", "type": "select", "colSpan": 1, "options": [{ "label": "Self", "value": "self" }, { "label": "Spouse", "value": "spouse" }, { "label": "Child", "value": "child" }, { "label": "Other", "value": "other" }], "fhirMapping": { "resource": "Coverage", "path": "relationship.coding[0].code", "type": "code" } },
        { "key": "policyNumber", "label": "Policy Number", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "identifier[0].value", "type": "string" } },
        { "key": "effectiveDate", "label": "Effective Date", "type": "date", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "period.start", "type": "date" } },
        { "key": "endDate", "label": "End Date", "type": "date", "colSpan": 1, "fhirMapping": { "resource": "Coverage", "path": "period.end", "type": "date" } },
        { "key": "status", "label": "Status", "type": "select", "colSpan": 1, "options": [{ "label": "Active", "value": "active" }, { "label": "Cancelled", "value": "cancelled" }, { "label": "Entered in Error", "value": "entered-in-error" }], "fhirMapping": { "resource": "Coverage", "path": "status", "type": "code" } }
      ]
    },
    {
