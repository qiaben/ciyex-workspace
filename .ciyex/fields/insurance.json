      "visible": true,
      "collapsible": true,
      "fields": [
        { "key": "copay", "label": "Copay Amount", "type": "number", "colSpan": 1, "placeholder": "0.00" },
        { "key": "deductible", "label": "Deductible", "type": "number", "colSpan": 1, "placeholder": "0.00" },
        { "key": "deductibleMet", "label": "Deductible Met", "type": "number", "colSpan": 1, "placeholder": "0.00" },
        { "key": "outOfPocketMax", "label": "Out-of-Pocket Max", "type": "number", "colSpan": 1, "placeholder": "0.00" },
        { "key": "coinsurance", "label": "Coinsurance (%)", "type": "number", "colSpan": 1, "validation": { "min": 0, "max": 100 } },
        { "key": "priorAuthRequired", "label": "Prior Auth Required", "type": "boolean", "colSpan": 1 }
      ]
