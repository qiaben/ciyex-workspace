{
  "tabKey": "medications",
  "fhirResources": ["MedicationRequest"],
  "sections": [
    {
      "key": "medication-list",
      "title": "Medications",
      "columns": 2,
      "visible": true,
      "collapsible": false,
      "fields": [
        { "key": "medicationName", "label": "Medication", "type": "coded", "required": true, "colSpan": 2, "fhirMapping": { "resource": "MedicationRequest", "path": "medicationCodeableConcept.coding", "type": "CodeableConcept" }, "codeLookupConfig": { "codeSystem": "NDC", "placeholder": "Search medications..." } },
        { "key": "medicationCode", "label": "NDC Code", "type": "text", "colSpan": 1, "readonly": true, "fhirMapping": { "resource": "MedicationRequest", "path": "medicationCodeableConcept.coding[0].code", "type": "string" } },
        { "key": "strength", "label": "Strength", "type": "text", "colSpan": 1, "placeholder": "e.g., 500mg, 10mg/5mL" },
        { "key": "dosageForm", "label": "Dosage Form", "type": "select", "colSpan": 1, "options": [{ "label": "Tablet", "value": "TAB" }, { "label": "Capsule", "value": "CAP" }, { "label": "Liquid", "value": "LIQ" }, { "label": "Injection", "value": "INJ" }, { "label": "Cream", "value": "CRM" }, { "label": "Ointment", "value": "OIN" }, { "label": "Patch", "value": "PAT" }, { "label": "Inhaler", "value": "INH" }, { "label": "Drops", "value": "DRP" }, { "label": "Suppository", "value": "SUP" }, { "label": "Solution", "value": "SOL" }, { "label": "Suspension", "value": "SUS" }] },
        { "key": "sig", "label": "Sig (Directions)", "type": "textarea", "colSpan": 1, "placeholder": "e.g., Take 1 tablet by mouth twice daily with food", "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].text", "type": "string" } },
        { "key": "dosage", "label": "Dosage", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].doseAndRate[0].doseQuantity.value", "type": "string" } },
        { "key": "frequency", "label": "Frequency", "type": "select", "colSpan": 1, "options": [{ "label": "Once daily", "value": "QD" }, { "label": "Twice daily", "value": "BID" }, { "label": "Three times daily", "value": "TID" }, { "label": "Four times daily", "value": "QID" }, { "label": "Every 4 hours", "value": "Q4H" }, { "label": "Every 6 hours", "value": "Q6H" }, { "label": "Every 8 hours", "value": "Q8H" }, { "label": "Every 12 hours", "value": "Q12H" }, { "label": "As needed", "value": "PRN" }, { "label": "At bedtime", "value": "QHS" }, { "label": "Every morning", "value": "QAM" }, { "label": "Weekly", "value": "QW" }, { "label": "Monthly", "value": "QM" }], "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].timing.code.coding[0].code", "type": "code" } },
        { "key": "route", "label": "Route", "type": "select", "colSpan": 1, "options": [{ "label": "Oral", "value": "PO" }, { "label": "Intravenous", "value": "IV" }, { "label": "Intramuscular", "value": "IM" }, { "label": "Subcutaneous", "value": "SC" }, { "label": "Topical", "value": "TOP" }, { "label": "Inhalation", "value": "INH" }, { "label": "Rectal", "value": "PR" }, { "label": "Sublingual", "value": "SL" }, { "label": "Transdermal", "value": "TD" }, { "label": "Ophthalmic", "value": "OP" }, { "label": "Otic", "value": "OT" }, { "label": "Nasal", "value": "NAS" }, { "label": "Vaginal", "value": "VAG" }], "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].route.coding[0].code", "type": "code" } },
        { "key": "quantity", "label": "Quantity", "type": "number", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dispenseRequest.quantity.value", "type": "decimal" } },
        { "key": "quantityUnit", "label": "Quantity Unit", "type": "select", "colSpan": 1, "options": [{ "label": "Tablets", "value": "TAB" }, { "label": "Capsules", "value": "CAP" }, { "label": "mL", "value": "mL" }, { "label": "Each", "value": "EA" }, { "label": "Patches", "value": "PAT" }, { "label": "Grams", "value": "g" }] },
        { "key": "refills", "label": "Refills", "type": "number", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dispenseRequest.numberOfRepeatsAllowed", "type": "integer" }, "validation": { "min": 0, "max": 99 } },
        { "key": "daysSupply", "label": "Days Supply", "type": "number", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dispenseRequest.expectedSupplyDuration.value", "type": "integer" } },
        { "key": "deaSchedule", "label": "DEA Schedule", "type": "select", "colSpan": 1, "options": [{ "label": "Not Controlled", "value": "none" }, { "label": "Schedule II", "value": "CII" }, { "label": "Schedule III", "value": "CIII" }, { "label": "Schedule IV", "value": "CIV" }, { "label": "Schedule V", "value": "CV" }] },
        { "key": "priority", "label": "Priority", "type": "select", "colSpan": 1, "options": [{ "label": "Routine", "value": "routine" }, { "label": "Urgent", "value": "urgent" }, { "label": "ASAP", "value": "asap" }, { "label": "STAT", "value": "stat" }], "fhirMapping": { "resource": "MedicationRequest", "path": "priority", "type": "code" } },
        { "key": "status", "label": "Status", "type": "select", "required": true, "colSpan": 1, "options": [{ "label": "Active", "value": "active" }, { "label": "On Hold", "value": "on-hold" }, { "label": "Cancelled", "value": "cancelled" }, { "label": "Completed", "value": "completed" }, { "label": "Stopped", "value": "stopped" }, { "label": "Draft", "value": "draft" }], "fhirMapping": { "resource": "MedicationRequest", "path": "status", "type": "code" } },
        { "key": "startDate", "label": "Start Date", "type": "date", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "authoredOn", "type": "datetime" } },
        { "key": "endDate", "label": "End Date", "type": "date", "colSpan": 1 },
        { "key": "prescriber", "label": "Prescriber", "type": "lookup", "colSpan": 1, "lookupConfig": { "endpoint": "/api/providers", "displayField": "fullName", "valueField": "id", "searchable": true }, "fhirMapping": { "resource": "MedicationRequest", "path": "requester.reference", "type": "Reference" } },
        { "key": "pharmacy", "label": "Pharmacy", "type": "lookup", "colSpan": 1, "lookupConfig": { "endpoint": "/api/pharmacies", "displayField": "name", "valueField": "id", "searchable": true } },
        { "key": "instructions", "label": "Patient Instructions", "type": "textarea", "colSpan": 2, "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].patientInstruction", "type": "string" } },
        { "key": "notes", "label": "Internal Notes", "type": "textarea", "colSpan": 2, "fhirMapping": { "resource": "MedicationRequest", "path": "note[0].text", "type": "string" } }
      ]
    }
  ]
}
