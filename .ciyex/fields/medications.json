        { "key": "frequency", "label": "Frequency", "type": "select", "colSpan": 1, "options": [{ "label": "Once daily", "value": "QD" }, { "label": "Twice daily", "value": "BID" }, { "label": "Three times daily", "value": "TID" }, { "label": "Four times daily", "value": "QID" }, { "label": "Every 4 hours", "value": "Q4H" }, { "label": "Every 6 hours", "value": "Q6H" }, { "label": "Every 8 hours", "value": "Q8H" }, { "label": "Every 12 hours", "value": "Q12H" }, { "label": "As needed", "value": "PRN" }, { "label": "At bedtime", "value": "QHS" }], "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].timing.code.coding[0].code", "type": "code" } },
        { "key": "route", "label": "Route", "type": "select", "colSpan": 1, "options": [{ "label": "Oral", "value": "PO" }, { "label": "Intravenous", "value": "IV" }, { "label": "Intramuscular", "value": "IM" }, { "label": "Subcutaneous", "value": "SC" }, { "label": "Topical", "value": "TOP" }, { "label": "Inhalation", "value": "INH" }, { "label": "Rectal", "value": "PR" }, { "label": "Sublingual", "value": "SL" }], "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].route.coding[0].code", "type": "code" } },
