        { "key": "refills", "label": "Refills", "type": "number", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dispenseRequest.numberOfRepeatsAllowed", "type": "integer" }, "validation": { "min": 0, "max": 99 } },
        { "key": "daysSupply", "label": "Days Supply", "type": "number", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "dispenseRequest.expectedSupplyDuration.value", "type": "integer" } },
        { "key": "status", "label": "Status", "type": "select", "required": true, "colSpan": 1, "options": [{ "label": "Active", "value": "active" }, { "label": "On Hold", "value": "on-hold" }, { "label": "Cancelled", "value": "cancelled" }, { "label": "Completed", "value": "completed" }, { "label": "Stopped", "value": "stopped" }], "fhirMapping": { "resource": "MedicationRequest", "path": "status", "type": "code" } },
        { "key": "startDate", "label": "Start Date", "type": "date", "colSpan": 1, "fhirMapping": { "resource": "MedicationRequest", "path": "authoredOn", "type": "datetime" } },
