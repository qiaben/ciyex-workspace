        { "key": "instructions", "label": "Patient Instructions", "type": "textarea", "colSpan": 2, "fhirMapping": { "resource": "MedicationRequest", "path": "dosageInstruction[0].patientInstruction", "type": "string" } },
        { "key": "notes", "label": "Internal Notes", "type": "textarea", "colSpan": 2, "fhirMapping": { "resource": "MedicationRequest", "path": "note[0].text", "type": "string" } }
