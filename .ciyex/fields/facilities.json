        { "key": "city", "label": "City", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "address.city", "type": "string" } },
        { "key": "state", "label": "State", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "address.state", "type": "string" } },
        { "key": "postalCode", "label": "ZIP Code", "type": "text", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "address.postalCode", "type": "string" } }
