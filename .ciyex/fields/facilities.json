        { "key": "status", "label": "Status", "type": "select", "colSpan": 1, "options": [{ "label": "Active", "value": "active" }, { "label": "Inactive", "value": "inactive" }, { "label": "Suspended", "value": "suspended" }], "fhirMapping": { "resource": "Location", "path": "status", "type": "code" } },
        { "key": "phone", "label": "Phone", "type": "phone", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "telecom[?system=phone].value", "type": "string" } },
        { "key": "fax", "label": "Fax", "type": "phone", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "telecom[?system=fax].value", "type": "string" } },
        { "key": "email", "label": "Email", "type": "email", "colSpan": 1, "fhirMapping": { "resource": "Location", "path": "telecom[?system=email].value", "type": "string" } },
