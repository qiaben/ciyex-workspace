FROM node:22-slim

LABEL org.opencontainers.image.title="Ciyex Workspace Web"
LABEL org.opencontainers.image.description="Ciyex Workspace accessible via browser"

ARG BUILD_DIR=../vscode-reh-web-linux-x64

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    procps \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash ciyex

WORKDIR /app

COPY ${BUILD_DIR} /app/

RUN chown -R ciyex:ciyex /app

USER ciyex

ENV VSCODE_AGENT_FOLDER=/home/ciyex/.ciyex-workspace-server

EXPOSE 8080

ENTRYPOINT ["node", "/app/server-main.js", \
    "--start-server", \
    "--host", "0.0.0.0", \
    "--port", "8080", \
    "--without-connection-token", \
    "--accept-server-license-terms"]
